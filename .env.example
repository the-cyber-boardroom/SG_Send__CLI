# SG/Send Vault Integration Test Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Vault key in format: {passphrase}:{vault_id}
SG_VAULT_KEY=

# Access token for write operations (optional for read-only tests)
SG_ACCESS_TOKEN=

# API base URL (default: https://send.sgraph.ai)
# SG_BASE_URL=https://send.sgraph.ai
